# -----------------------------------------------------------------------------
# EduGenie environment configuration
# Copy this file to ".env" and fill in your values.
# -----------------------------------------------------------------------------

# Your Google Gemini API key (required).
# Get one for free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini model to use (optional).
# Defaults to gemini-2.5-flash if this is left unset.
GEMINI_MODEL=gemini-2.5-flash
